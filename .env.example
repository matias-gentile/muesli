# Copia este archivo a .env y rellena tu API key
# NUNCA subas .env a git (ya está en .gitignore)

ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude para los resúmenes.
# Opciones: claude-sonnet-4-6 (recomendado), claude-opus-4-8 (más calidad),
#           claude-haiku-4-5-20251001 (más barato/rápido)
CLAUDE_MODEL=claude-sonnet-4-6

# Tamaño del modelo Whisper: tiny | base | small | medium | large-v3
# 'base' o 'small' van bien en un Mac. Más grande = más preciso y más lento.
WHISPER_MODEL=base

# Substring del nombre de tu dispositivo agregado en Audio MIDI Setup
# (el que combina BlackHole + tu micrófono). Ver README.
AUDIO_DEVICE_NAME=Aggregate
