# Copia este archivo a .env y rellena tu API key
# NUNCA subas .env a git (ya está en .gitignore)

ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude para los resúmenes.
# Opciones: claude-sonnet-4-6 (recomendado), claude-opus-4-8 (más calidad),
#           claude-haiku-4-5-20251001 (más barato/rápido)
CLAUDE_MODEL=claude-sonnet-4-6

# Tamaño del modelo Whisper: tiny | base | small | medium | large-v3
# 'base' o 'small' van bien en un Mac. Más grande = más preciso y más lento.
WHISPER_MODEL=base

# Filtro de voz (VAD) de Whisper. 0 = off (más permisivo con audio bajo),
# 1 = on (descarta silencios; útil si ves texto "alucinado").
WHISPER_VAD=0

# Substring del nombre de tu dispositivo agregado en Audio MIDI Setup
# (el que combina BlackHole + tu micrófono). Se usa en modo "salida + micrófono".
AUDIO_DEVICE_NAME=Aggregate

# Dispositivo para el modo "solo salida" (captura el sonido del sistema, sin tu mic).
# Normalmente BlackHole directo; no hace falta tocarlo.
AUDIO_DEVICE_OUTPUT_ONLY=BlackHole

# Duración de cada segmento de grabación, en segundos (para reuniones largas).
# 600 = 10 min. Más chico = más resiliente y progreso más fino; más grande = menos archivos.
CHUNK_SECONDS=600

# --- Notion (opcional) ---
# Si los dos están definidos, cada grabación se crea como página en tu base de Notion.
# 1. Crear integración: https://www.notion.so/my-integrations  (copiá el "Internal Integration Token")
# 2. Crear una base de datos y compartirla con la integración (••• → Conexiones)
# 3. El ID de la base está en la URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_API_KEY=
NOTION_DATABASE_ID=
